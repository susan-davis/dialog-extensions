#wrap-around-3d6
(test *)
(run test *)
	(now) (3d6 list position 215)
	(roll three #d6 2 2 3)
	~(3d6 has rolled over)
	(roll three #d6 6 1 2)
	~(3d6 has rolled over)
	(roll three #d6 4 5 6)
	(3d6 has rolled over)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(roll three #d6 5 1 5)

