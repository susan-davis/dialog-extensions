%% dgdebug -u more-dice-tests.dg more-dice.dg dice.dg utils.dg unit.dg stdlib.dg

(list of tests [
	  #2d3-individual
	  #2d3-total
	  #d4
	  #2d6-daro
	  #3d6-taro
	  #d6xd6
	  #min-mid-max
	  #d8
	  #d12
	  #d20-with-advantage
	  #d20-with-disadvantage
	  #1dF
	  #2dF
	  #4dF
	  #4d-attack-roll-with-spite
	  #5d-attack-roll-with-spite
	  #6d-attack-roll-with-spite
	  #7-die-pool-against-target
	  #8-die-pool-against-target
	  #9-die-pool-against-target
	  ])

(set up $)	(reset randomness)

%%-----------------------------------------------------------------------------

(test #2d3-individual)
	(2d3 2 3)
	(2d3 2 2)
	(2d3 3 2)
	(2d3 3 3)
	(2d3 1 2)
	(2d3 3 1)

(test #2d3-total)
	(2d3 5)
	(2d3 4)
	(2d3 5)
	(2d3 6)
	(2d3 3)
	(2d3 4)

(test #d4)
	(d4 4)
	(d4 2)
	(d4 2)
	(d4 4)
	(d4 3)
	(d4 1)

(test #2d6-daro)
	(now) (3d6 list position 9)
	(2d6 9 DARO)
	(2d6 18 DARO)
	(3d6 list position 13)
	(2d6 5 DARO)
	(now) (3d6 list position 17)
	(2d6 5 DARO)
	(3d6 list position 19)

(test #3d6-taro)
	(now) (3d6 list position 9)
	(3d6 10 TARO)
	(3d6 14 TARO)
	(3d6 11 TARO)
	(3d6 list position 13)

(test #d6xd6)
	(d6 times d6 20)
	(d6 times d6 12)
	(d6 times d6 15)
	(d6 times d6 30)
	(d6 times d6 4)
	(d6 times d6 5)
	(d6 times d6 18)

(test #min-mid-max)
	(min mid max 4 5 6)
	(min mid max 1 3 4)
	(min mid max 3 5 6)
	(min mid max 5 6 6)
	(min mid max 1 4 6)
	(min mid max 1 5 5)

(test #d8)
    (d8 8)
	(d8 4)
	(d8 5)
	(d8 8)
	(d8 6)
	(d8 2)

(test #d12)
    (d12 10)
	(d12 5)
	(d12 6)
	(d12 10)
	(d12 8)
	(d12 2)

(test #d20-with-advantage)
	(d20 19 with advantage)
	(d20 16 with advantage)
	(d20 12 with advantage)
	(d20 13 with advantage)

(test #d20-with-disadvantage)
	(d20 13 with disadvantage)
	(d20 15 with disadvantage)
	(d20 9 with disadvantage)
	(d20 4 with disadvantage)

(test #1dF)
	(1dF #up   1)
	(1dF #down 1)
	(1dF #up   1)
	(1dF #up   1)
	(1dF #up   1)
	(1dF #up   1)

(test #2dF)
	(2dF #up   1)
	(2dF 0     0)
	(2dF #up   1)
	(2dF #up   2)
	(2dF #down 1)
	(2dF 0     0)

(test #4dF)
	(4dF #up   1)
	(4dF #up   3)
	(4dF #down 1)
	(4dF #up   2)
	(4dF #down 1)
	(4dF #up   1)

(test #4d-attack-roll-with-spite)
	(roll 4 dice 16 1)
	(roll 4 dice 20 2)
	(roll 4 dice 16 1)
	(roll 4 dice 19 2)

(test #5d-attack-roll-with-spite)
	(roll 5 dice 22 1)
	(roll 5 dice 25 2)
	(roll 5 dice 17 1)
	(roll 5 dice 24 3)

(test #6d-attack-roll-with-spite)
	(roll 6 dice 23 1)
	(roll 6 dice 31 3)
	(roll 6 dice 22 1)
	(roll 6 dice 28 3)

(test #7-die-pool-against-target)
	(roll 7 dice with target 5 into 3)
	(roll 7 dice with target 5 into 5)
	(roll 7 dice with target 5 into 3)
	(roll 7 dice with target 5 into 3)
	(roll 7 dice with target 5 into 1)

(test #8-die-pool-against-target)
	(roll 8 dice with target 5 into 3)
	(roll 8 dice with target 5 into 5)
	(roll 8 dice with target 5 into 4)
	(roll 8 dice with target 5 into 2)
	(roll 8 dice with target 5 into 1)

(test #9-die-pool-against-target)
	(roll 9 dice with target 5 into 4)
	(roll 9 dice with target 5 into 6)
	(roll 9 dice with target 5 into 4)
	(roll 9 dice with target 5 into 3)
	(roll 9 dice with target 5 into 1)
