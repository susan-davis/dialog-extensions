(random roll 223 10125) %% 223 is a prime number

%% In the above, 3d6 is fair, and d20 is fair, but don't combine 3d6 with d20.

(global variable (3d6 list position 1))

(global variable (saved roll 0)) %% be parsimonious about advancing position

~(3d6 has rolled over) %% ignore if you shuffle randomess

(global variable (d20 list position 1))

~(d20 has rolled over) %% ignore if you shuffle randomness

%% Starting at the beginning of the list gives the same output for every single
%% game, which is good for unit tests, but can allow sketchy exploits in games.
%% Call this once at the beginning of (program entry point) to start from a
%% random spot in the list instead. Change the rollover points to 223 if you
%% call for the same number of random rolls every cycle.

(shuffle randomness)
	(random from 1 to 216 into $Position) %% or 223
	(now) (3d6 list position $Position)
	(random from 1 to 220 into $Pos) %% or 223
	(now) (d20 list position $Pos)

(reset randomness)
	(now) (3d6 list position 1)
	(now) ~(3d6 has rolled over)
	(now) (saved roll 0)
	(now) (d20 list position 1)
	(now) ~(d20 has rolled over)

(3d6 choice $Num)
	(3d6 list position $Pos)
	(if) { ($Pos = 0) (or) ($Pos > 216) } (then) %% or 223
		($Position = 1)
	    (now) (3d6 list position $Position)
		(now) (3d6 has rolled over)
	(else)
		(3d6 list position $Position)
	(endif)
	(random roll $Position $Num)
	($Position plus 1 into $NewPosition)
	(now) (3d6 list position $NewPosition)

(d20 choice $Num)
	(d20 list position $Pos)
	(if) { ($Pos = 0) (or) ($Pos > 220) } (then) %% or 223
		($Position = 1)
	    (now) (d20 list position $Position)
		(now) (d20 has rolled over)
	(else)
		(d20 list position $Position)
	(endif)
	(random roll $Position $Num)
	($Position plus 1 into $NewPosition)
	(now) (d20 list position $NewPosition)

%%-----------------------------------------------------------------------------

#d3

(roll * $Roll)
    (roll #d6 $Die)
    ($Die divided by 2 into $Roll rounding up)

(roll two * $First $Second)
	(roll two #d6 $One $Two)
	($One divided by 2 into $First rounding up)
	($Two divided by 2 into $Second rounding up)

(roll three * $First $Second $Third)
	(roll three #d6 $One $Two $Three)
	($One divided by 2 into $First rounding up)
	($Two divided by 2 into $Second rounding up)
	($Three divided by 2 into $Third rounding up)

#d4

(roll * $Roll)
	(roll #d20 $Die)
	($Die divided by 5 into $Roll rounding up)

(roll two * $First $Second)
	(roll #d20 max 16 $Roll)
	($Roll divided by 4 into $First rounding up)
	($Roll modulo 4 into $Ones)
	($Ones plus 1 into $Second)

(roll three * $First $Second $Third)
	(roll #d72 max 64 $Roll)
	($Roll divided by 16 into $First rounding up)
	($Roll modulo 16 into $Sixteen)
	($Sixteen divided by 4 into $Second rounding up)
	($Sixteen modulo 4 into $Ones)
	($Ones plus 1 into $Third)

#d6

(roll * $Roll)
	(saved roll $Saved)
	(if) ($Saved > 0) (then)
		($Saved modulo 10 into $Roll)
		($Saved divided by 10 into $New)
	(else)
		(3d6 choice $N)
		($N modulo 1000 into $Num) %% never save the d10 as a d6
		($Num modulo 10 into $Roll)
		($Num divided by 10 into $New)
	(endif)
	(now) (saved roll $New)

(roll two * $First $Second)
	(3d6 choice $Num) %% always use a fresh 2d6 roll, to retain fairness
	(split $Num into $ $First $Second $Lower)
	(saved roll $Saved)
	(if) ($Saved < 667) (then)
		($Saved times 10 into $Upper)
		($Upper plus $Lower into $New)
	(else)
		($Saved = $New)
	(endif)
	(now) (saved roll $New)

(roll three * $First $Second $Third)
	(3d6 choice $Num) %% always use a fresh 3d6 roll, to retain fairness
	(split $Num into $ $First $Second $Third)

#d8

(roll * $Roll)
	(roll #d10 max 8 $Roll)

(roll two * $First $Second)
	(roll #d72 max 64 $Roll)
	($Roll divided by 8 into $First rounding up)
	($Roll modulo 8 into $Two)
	($Two plus 1 into $Second)

#d10

(roll * $Roll)
	(d20 choice $Num)
	(split $Num into $Roll $ $ $)

(roll two * $First $Second)
	(roll #d100 $Roll)
	(split $Roll into $ $ $First $Second)

#d12

(roll * $Roll)
	(roll #d36 $Die)
	($Die divided by 3 into $Roll rounding up)

#d20

(roll * $Roll)
	(d20 choice $Num)
	(split $Num into $Tens $Sixes $ $)
	(if) ($Sixes > 3) (then)
		($Tens plus 10 into $Roll)
	(else)
		($Tens = $Roll)
	(endif)

#d36

(roll * $Total)
	(3d6 choice $Num)
	(split $Num into $ $ $Two $Ones)
	($Two minus 1 into $Second)
	($Second times 6 into $Sixes)
	($Sixes plus $Ones into $Total)

#d72

(roll * $Total)
	(roll #d216 $Roll)
	($Roll divided by 3 into $Total rounding up)

#d100

(roll * $Percent)
	(roll #d216 max 200 $Roll)
	($Roll divided by 2 into $Percent rounding up)

#d216

(roll * $Total)
	(3d6 choice $Num)
	(split $Num into $ $Third $Second $Ones)
	($Second minus 1 into $Middle)
	($Middle times 6 into $Sixes)
	($Ones plus $Sixes into $Sum)
	($Third minus 1 into $Upper)
	($Upper times 36 into $ThirtySixes)
	($ThirtySixes plus $Sum into $Total)

%%-----------------------------------------------------------------------------

(dF $Roll $Delta $Direction $Total)
	($Roll delta $Delta into $Total)
	(if) ($Roll > $Delta) (then)
		($Direction = #up)
	(elseif) ($Roll < $Delta) (then)
		($Direction = #down)
	(else)
		($Direction = 0)
	(endif)

(roll 1dF $Direction $Num)
	(roll #d3 $Roll)
	(dF $Roll 2 $Direction $Num)

(roll 2dF $Direction $Total)
	(roll 2 #d3 $Roll)
	(dF $Roll 4 $Direction $Total)

($Num plus 2dF $Total)
	(roll 2dF $Direction $Roll)
	(if) ($Direction = #down) (then)
		(if) ($Roll > $Num) (then)
			($Total = 0)
		(else)
			($Num minus $Roll into $Total)
		(endif)
	(else)
		($Num plus $Roll into $Total)
	(endif)

(roll 4dF $Direction $Total)
	(roll 4 #d3 $Roll)
	(dF $Roll 8 $Direction $Total)

($Num plus 4dF $Total)
	(roll 4dF $Direction $Roll)
	(if) ($Direction = #down) (then)
		(if) ($Roll > $Num) (then)
			($Total = 0)
		(else)
			($Num minus $Roll into $Total)
		(endif)
	(else)
		($Num plus $Roll into $Total)
	(endif)

%%-----------------------------------------------------------------------------

(roll two $Dice $First $Second)
	(roll $Dice $First)
	(roll $Dice $Second)

(roll three $Dice $First $Second $Third)
	(roll two $Dice $First $Second)
	(roll $Dice $Third)

(roll four $Dice $First $Second $Third $Fourth)
	(roll two $Dice $First $Second)
	(roll two $Dice $Third $Fourth)

(roll $Die max $Max $Total)
	(roll $Die $Roll)
	(if) ($Roll > $Max) (then)
		(roll $Die max $Max $Total) %% roll again
	(else)
		($Roll = $Total)
	(endif)

(roll $Die plus $Adds $Total)
	(roll $Die $Roll)
	($Roll plus $Adds into $Total)

(roll $Die minus $Penalty $Total)
	(roll $Die $Roll)
	(if) ($Penalty > $Roll) (then)
		($Total = 0)
	(else)
		($Roll minus $Penalty into $Total)
	(endif)

(roll $Die $Roll with advantage)
	(roll two $Die $First $Second)
	(max $First $Second $Roll)

(roll $Die $Roll with disadvantage)
	(roll two $Die $First $Second)
	(min $First $Second $Roll)

(roll $Die min mid max $Min $Mid $Max)
	(roll three $Die $First $Second $Third)
	(sort $First $Second $Third into $Min $Mid $Max)

(roll $Die1 $Die2 $Die3 min mid max $Min $Mid $Max)
	(roll $Die1 $First)
	(roll $Die2 $Second)
	(roll $Die3 $Third)
	(sort $First $Second $Third into $Min $Mid $Max)

(roll $Die1 times $Die2 $Total)
	(if) ($Die1 = $Die2) (then)
		(roll two $Die1 $First $Second)
	(else)
		(roll $Die1 $First)
		(roll $Die2 $Second)
	(endif)
	($First times $Second into $Total)

(roll $Die1 times $Die2 adding $Bonus $Total)
	(roll $Die1 $One)
	(roll $Die2 $Two)
	(sort $One $Two into $Low $Second)
	($Low plus $Bonus into $First)
	($First times $Second into $Total)

(roll $Die1 times $Die2 subtracting $Penalty $Total)
	(roll $Die1 $One)
	(roll $Die2 $Two)
	(sort $One $Two into $Low $Second)
	(if) ($Low > $Penalty) (then)
		($Low minus $Penalty into $First)
	(else)
		($First = 1)
	(endif)
	($First times $Second into $Total)

(roll two $Dice $Total DARO)
	(roll two $Dice $First $Second)
	(if) ($First = $Second) (then)
		($First plus $Second into $Sum)
		(roll two $Dice $Bonus DARO)
		($Sum plus $Bonus into $Total)
	(else)
		($First plus $Second into $Total)
	(endif)

(roll two $Dice plus $Adds $Total DARO)
	(roll two $Dice $Subtotal DARO)
	($Subtotal plus $Adds into $Total)

(roll three $Dice $Total TARO)
	(roll three $Dice $First $Second $Third)
	($First plus $Second into $FirstTwo)
	(if) ($First = $Second) ($Second = $Third) (then)
		($FirstTwo plus $Third into $Sum)
		(roll three $Dice $Bonus TARO)
		($Sum plus $Bonus into $Total)
	(else)
		($FirstTwo plus $Third into $Total)
	(endif)

(roll three $Dice plus $Adds $Total TARO)
	(roll three $Dice $Subtotal TARO)
	($Subtotal plus $Adds into $Total)

(match die $Die $Target $OldCount $NewCount)
	(if) ($Die = $Target) (then)
	    (add 1 to $OldCount into $NewCount)
	(else)
		($OldCount = $NewCount)
	(endif)

(roll 0 $ $Total with $Ones spite)
	($Total = 0)
	($Ones = 0)

(roll 1 $Die $Total with $Ones spite)
	(roll $Die $Total)
	(match die $Total 1 0 $Ones)

(roll 2 $Dice $Total with $Ones spite)
	(roll two $Dice $First $Second)
	($First plus $Second into $Total)
	(match die $First 1 0 $S1)
	(match die $Second 1 $S1 $Ones)

(roll $Num $Dice $Total with $Ones spite)
	(roll three $Dice $First $Second $Third)
	($First plus $Second into $FirstTwo)
	($FirstTwo plus $Third into $Roll)
	(match die $First 1 0 $S1)
	(match die $Second 1 $S1 $S2)
	(match die $Third 1 $S2 $S3)
	($Num minus 3 into $Remaining)
	(roll $Remaining $Dice $More with $MoreOnes spite)
	($Roll plus $More into $Total)
	($S3 plus $MoreOnes into $Ones)

(roll $Num $Dice plus $Adds $Total with $Ones spite)
	(roll $Num $Dice $Subtotal with $Ones spite)
	($Subtotal plus $Adds into $Total)

(roll $Num $Dice $Total)
	(roll $Num $Dice $Total with $ spite)

(roll $Num $Dice plus $Adds $Total)
	(roll $Num $Dice $Subtotal)
	($Subtotal plus $Adds into $Total)

(roll $Num $Dice minus $Penalty $Total)
	(roll $Num $Dice $Subtotal)
	(if) ($Penalty > $Subtotal) (then)
		($Total = 0)
	(else)
		($Subtotal minus $Penalty into $Total)
	(endif)

(target die $Die $Target $OldCount $NewCount)
	(if) ($Die < $Target) (then)
		($OldCount = $NewCount)
	(else)
	    (add 1 to $OldCount into $NewCount)
	(endif)

(roll 0 $ with target $ into 0)

(roll 1 $Die with target $Target into $Successes)
	(roll $Die $Roll)
	(target die $Roll $Target 0 $Successes)

(roll 2 $Dice with target $Target into $Successes)
    (roll two $Dice $First $Second)
	(target die $First $Target 0 $S1)
	(target die $Second $Target $S1 $Successes)

(roll $Num $Dice with target $Target into $Successes)
	(roll three $Dice $First $Second $Third)
	(target die $First $Target 0 $S1)
	(target die $Second $Target $S1 $S2)
	(target die $Third $Target $S2 $S3)
	($Num minus 3 into $Remaining)
	(roll $Remaining $Dice with target $Target into $More)
	($S3 plus $More into $Successes)

(percentage of 0 into 0)

(percentage of 1 into 1)

(percentage of 2 into $Percentage)
	(roll #d10 $Roll)
	($Roll divided by 5 into $Percentage rounding up)

(percentage of 3 into $Percentage)
	(roll #d3 $Percentage)

(percentage of 4 into $Percentage)
	(roll #d4 $Percentage)

%% TODO: make it not fall over for 16383
(percentage of $Num into $Percentage)
	(if) ($Num < 7) (then)
		(roll #d6 max $Num $Percentage)
	(elseif) ($Num < 11) (then)
		(roll #d10 max $Num $Percentage)
	(elseif) ($Num < 13) (then)
		(roll #d12 max $Num $Percentage)
	(elseif) ($Num < 21) (then)
		(roll #d20 max $Num $Percentage)
	(elseif) ($Num < 37) (then)
		(roll #d36 max $Num $Percentage)
	(elseif) ($Num < 73) (then)
		(roll #d72 max $Num $Percentage)
	(elseif) ($Num < 109) (then)
		($Num times 2 into $Max)
		(roll #d216 max $Max $Roll)
		($Roll divided by 2 into $Percentage rounding up)
	(elseif) ($Num < 217) (then)
		(roll #d216 max $Num $Percentage)
	(else)
		($Num divided by 216 into $Div)
		($Num modulo 216 into $Mod)
		(roll #d216 $Roll)
		($Roll times $Div into $Product)
		(percentage of $Mod into $Remainder)
		($Product plus $Remainder into $Percentage)
	(endif)

(randomly select $Choice from $List)
	(length of $List into $Length)
	(percentage of $Length into $Percent)
