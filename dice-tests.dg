%% dgdebug -u dice-tests.dg dice.dg unit.dg stdlib.dg

(set up $) (reset randomness)

#randomize-position
(test *)
(run test *)
	(shuffle randomness)
	(3d6 list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos
	(d20 list position $Pos20)
	(assert $Pos20 > 0)
	(assert $Pos20 < 221)
	$Pos20

#reset-randomness
(test *)
(run test *)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll two #d6 6 5)
	(saved roll 6)
	(3d6 list position 5)
	(reset randomness)
	(3d6 list position 1)
	(saved roll 0)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(3d6 list position 4)

#1d3
(test *)
(run test *)
	(roll #d3 3)
	(roll #d3 3)
	(saved roll 4)
	(roll #d3 2)
	(roll #d3 1)
	(saved roll 43)
	(roll #d3 2)
	(saved roll 4)

