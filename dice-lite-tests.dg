%% dgdebug -u dice-lite-tests.dg dice-lite.dg unit.dg stdlib.dg

(set up $)	(reset randomness)

($ 0 times with max $) %% do nothing

($Dice $N times with max $Max)
	(roll $Dice $Roll)
	($Roll > 0) ~($Roll > $Max)
	($N minus 1 into $NMinusOne)
	($Dice $NMinusOne times with max $Max)

#d3
(test *)
(run *)
	(* 1000 times with max 3)

#d4
(test *)
(run *)
	(* 1000 times with max 4)

