%% dgdebug -u grid-movement-tests.dg grid-movement.dg grid.dg utils.dg \
%%         unit.dg stdlib.dg

~(y increases south)
(x increases west)

#prairie
(grid *)
(descr *) Gently rolling hills covered with prairie grass stretch out in all
	   	  directions.
(from 81 11 in * go #northeast to #lecompton)
(from 80 11 in * go #north to #lecompton)
(from 79 11 in * go #northwest to #lecompton)


#lecompton
(room *)
(from * go #southeast to 79 9 in #prairie)
(from * go #south to 80 9 in #prairie)
(from * go #southwest to 81 9 in #prairie)

#prairie-city
(room *)
(* is at 60 80 in #prairie)

#calhoun
(room *)
(* is at 40 70 in #prairie)

#black-jack
(room *)
(* is at 20 80 in #prairie)

#player
(* is #in #lecompton)

(set up $)
    (now) (#player is #in #lecompton)

%%-----------------------------------------------------------------------------

#north-of-calhoun-is-not-80-10
(test *)
%%(run *)
	 ~(from #calhoun go #north to 80 10 in #prairie)
	 ~(from 80 10 in #prairie go #south to #calhoun)

#north-of-calhoun-is-40-71
(test *)
(run *)
	 (from #calhoun go #north to 40 71 in #prairie)
	 (from 40 71 in #prairie go #south to #calhoun)

#lecompton-to-grid
%%(test *)
(run *)
	 (stoppable) (perform [go #south])
	 (#player is #in #prairie)
	 (#player position [80 11])
