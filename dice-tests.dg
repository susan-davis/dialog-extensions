#one-roll
(test *)
(run test *)
	(roll #d6 6)
	(3d6 list position 2)
	(roll #d6 5)
	(roll #d6 4)
	(3d6 list position 2)
	(roll #d6 1)
	(3d6 list position 3)
	(roll #d6 3)
	~(3d6 has rolled over)

#1d6-plus-3
(test *)
(run test *)
	(roll #d6 plus 3 9)
	(roll #d6 plus 3 8)
	(roll #d6 plus 3 7)
	(roll #d6 plus 3 4)
	(roll #d6 plus 3 6)

#1d6-minus-3
(test *)
(run test *)
	(roll #d6 minus 3 3)
	(roll #d6 minus 3 2)
	(roll #d6 minus 3 1)
	(roll #d6 minus 3 0)
	(roll #d6 minus 3 0)

#wrap-around-1d6
(test *)
(run test *)
 	(now) (3d6 list position 215)
	(roll #d6 3)
	(roll #d6 2)
	(roll #d6 2)
	(3d6 list position 216)
	(roll #d6 2)
	(3d6 list position 217)
	(roll #d6 1)
	~(3d6 has rolled over)
	(roll #d6 6)
	~(3d6 has rolled over)
	(3d6 list position 217)
	(roll #d6 6)
	(3d6 has rolled over)
	(3d6 list position 2)
	(roll #d6 5)

