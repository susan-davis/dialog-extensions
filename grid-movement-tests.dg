%%         unit.dg stdlib.dg

~(y increases south)
(x increases west)

#prairie
(grid *)
(descr *) Gently rolling hills covered with prairie grass stretch out in all
	   	  directions.

#lecompton
(room *)
(from * go #southeast to 79 11 in #prairie)
(from * go #south to 80 11 in #prairie)
(from 81 11 in #prairie go #northeast to #lecompton)

#prairie-city
(room *)
(* is at 60 80 in #prairie)

#calhoun
(room *)
(* is at 40 70 in #prairie)

#black-jack
(room *)
(* is at 20 80 in #prairie)

#player
(* is #in #lecompton)

(set up $)
    (now) (#player is #in #lecompton)

%%-----------------------------------------------------------------------------

#lecompton-to-grid
(test *)
(run *)
	 (stoppable) (perform [go #south])
	 (#player is #in #prairie)
	 (#player position [80 10])
