%% dice.dg
%% include utils.dg when compiling or debugging

%% If Dialog issue #12 (PRNG with a predicate to specify the seed) is
%% implemented, this can be replaced, assuming that the PRNG passes
%% spectral tests.

(extension version)	Undo-safe die rolls v0.3 by Susan Davis (line)b

