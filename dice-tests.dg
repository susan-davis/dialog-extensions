%% dgdebug -u dice-tests.dg dice.dg unit.dg stdlib.dg

(list of tests [
	  #randomize-position
	  #reset-randomness
	  #1d3
	  #one-roll
	  #wrap-around-1d6
	  #two-roll-individual
	  #two-roll-total
	  #three-roll-individual
	  #three-roll-total
	  #wrap-around-3d6
	  #mix-one-and-three
	  #2d10-total
	  #2d10-individual
	  #d36
	  #d100
	  #d216
	  #1d10
	  #d20
	  #2d3-individual
	  #2d3-total
	  #d4
	  #2d6-daro
	  #3d6-taro
	  #d6xd6
	  #min-mid-max
	  #d8
	  #d12
	  #d20-with-advantage
	  #d20-with-disadvantage
	  #1dF
	  #2dF
	  #4dF
	  #4d-attack-roll-with-spite
	  #5d-attack-roll-with-spite
	  #6d-attack-roll-with-spite
	  #7-die-pool-against-target
	  #8-die-pool-against-target
	  #9-die-pool-against-target
	  #zero-percent
	  #one-percent
	  ])

%%-----------------------------------------------------------------------------

(set up $) (reset randomness)

%%-----------------------------------------------------------------------------

(test #1d3)
	(roll #d3 3)
	(roll #d3 1)
	(roll #d3 3)
	(roll #d3 3)
	(roll #d3 3)

(test #one-roll)
	(roll #d6 6)
	(roll #d6 1)
	(roll #d6 6)
	(roll #d6 6)
	(roll #d6 6)
	(roll #d6 5)

(test #wrap-around-1d6)
 	(now) (3d6 list position 215)
	(roll #d6 3)
	(roll #d6 2)
	(roll #d6 6)
	(roll #d6 1)
	(roll #d6 6)

(test #two-roll-individual)
	(roll 2 #d6 9)
	(roll 2 #d6 7)
	(roll 2 #d6 8)
	(roll 2 #d6 11)
	(roll 2 #d6 5)
	(roll 2 #d6 6)

(test #two-roll-total)
	(roll two #d6 4 5)
	(roll two #d6 4 3)
	(roll two #d6 5 3)
	(roll two #d6 6 5)
	(roll two #d6 1 4)
	(roll two #d6 5 1)

(test #three-roll-individual)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(roll three #d6 5 1 5)

(test #three-roll-total)
	(roll 3 #d6 15)
	(roll 3 #d6 8)
	(roll 3 #d6 14)
	(roll 3 #d6 17)
	(roll 3 #d6 11)
	(roll 3 #d6 11)

(test #wrap-around-3d6)
	(now) (3d6 list position 215)
	(roll three #d6 2 2 3)
	(roll three #d6 6 1 2)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(roll three #d6 5 1 5)

(test #mix-one-and-three)
	(roll #d6 6)
	(roll three #d6 4 3 1)
	(roll #d6 6)
	(roll #d6 6)
	(roll three #d6 1 4 6)
	(roll #d6 5)
	(roll #d6 6)
	(roll #d6 4)
	(roll three #d6 4 5 1)

(test #d36)
    (roll #d36 30)
	(roll #d36 13)
	(roll #d36 18)
	(roll #d36 30)
	(roll #d36 24)
	(roll #d36 5)

(test #d216)
	(roll #d216 138)
	(roll #d216 121)
	(roll #d216 162)
	(roll #d216 210)
	(roll #d216 24)
	(roll #d216 149)

(test #2d10-individual)
	(roll two #d10 6 9)
	(roll two #d10 6 1)
	(roll two #d10 8 1)
	(roll two #d10 1 2)
	(roll two #d10 7 5)
	(roll two #d10 5 4)
	(roll two #d10 9 8)

(test #2d10-total)
	(roll 2 #d10 15)
	(roll 2 #d10 7)
	(roll 2 #d10 9)
	(roll 2 #d10 3)
	(roll 2 #d10 12)
	(roll 2 #d10 9)
	(roll 2 #d10 17)

(test #d100)
	(roll #d100 69)
	(roll #d100 61)
	(roll #d100 81)
	(roll #d100 12)
	(roll #d100 75)
	(roll #d100 54)
	(roll #d100 98)

(test #1d10)
	(roll #d10 9)
	(roll #d10 3)
	(roll #d10 6)
	(roll #d10 5)
	(roll #d10 9)
	(roll #d10 2)
	(roll #d10 4)
	(roll #d10 3)

(test #d20)
	(roll #d20 19)
	(roll #d20 13)
	(roll #d20 16)
	(roll #d20 15)
	(roll #d20 9)
	(roll #d20 12)
	(roll #d20 4)
	(roll #d20 13)

(test #randomize-position)
	(shuffle randomness)
	(3d6 list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos

(test #reset-randomness)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(reset randomness)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)

(test #2d3-individual)
	(roll two #d3 2 3)
	(roll two #d3 2 2)
	(roll two #d3 3 2)
	(roll two #d3 3 3)
	(roll two #d3 1 2)
	(roll two #d3 3 1)

(test #2d3-total)
	(roll 2 #d3 5)
	(roll 2 #d3 4)
	(roll 2 #d3 5)
	(roll 2 #d3 6)
	(roll 2 #d3 3)
	(roll 2 #d3 4)

(test #d4)
	(roll #d4 4)
	(roll #d4 3)
	(roll #d4 4)
	(roll #d4 3)
	(roll #d4 2)
	(roll #d4 3)

(test #2d6-daro)
	(now) (3d6 list position 9)
	(roll two #d6 9 DARO)
	(roll two #d6 18 DARO)
	(3d6 list position 13)
	(roll two #d6 5 DARO)
	(now) (3d6 list position 17)
	(roll two #d6 5 DARO)
	(3d6 list position 19)

(test #3d6-taro)
	(now) (3d6 list position 9)
	(roll three #d6 10 TARO)
	(roll three #d6 14 TARO)
	(roll three #d6 11 TARO)
	(3d6 list position 13)

(test #d6xd6)
	(roll #d6 times #d6 20)
	(roll #d6 times #d6 12)
	(roll #d6 times #d6 15)
	(roll #d6 times #d6 30)
	(roll #d6 times #d6 4)
	(roll #d6 times #d6 5)
	(roll #d6 times #d6 18)

(test #min-mid-max)
	(roll #d6 min mid max 4 5 6)
	(roll #d6 min mid max 1 3 4)
	(roll #d6 min mid max 3 5 6)
	(roll #d6 min mid max 5 6 6)
	(roll #d6 min mid max 1 4 6)
	(roll #d6 min mid max 1 5 5)

(test #d8)
	(roll #d8 3)
	(roll #d8 6)
	(roll #d8 5)
	(roll #d8 2)
	(roll #d8 4)
	(roll #d8 3)

(test #d12)
    (roll #d12 10)
	(roll #d12 5)
	(roll #d12 6)
	(roll #d12 10)
	(roll #d12 8)
	(roll #d12 2)

(test #d20-with-advantage)
	(roll #d20 19 with advantage)
	(roll #d20 16 with advantage)
	(roll #d20 12 with advantage)
	(roll #d20 13 with advantage)
	(roll #d20 11 with advantage)

(test #d20-with-disadvantage)
	(roll #d20 13 with disadvantage)
	(roll #d20 15 with disadvantage)
	(roll #d20 9 with disadvantage)
	(roll #d20 4 with disadvantage)
	(roll #d20 2 with disadvantage)

(test #1dF)
	(roll 1dF #up   1)
	(roll 1dF #down 1)
	(roll 1dF #up   1)
	(roll 1dF #up   1)
	(roll 1dF #up   1)
	(roll 1dF #up   1)

(test #2dF)
	(roll 2dF $A    $B) $A $B

(test #4dF)
	(roll 4dF $A    $B) $A $B

(test #4d-attack-roll-with-spite)
	(roll 4 #d6 16 with 1 spite)
	(roll 4 #d6 20 with 0 spite)
	(roll 4 #d6 16 with 1 spite)
	(roll 4 #d6 19 with 0 spite)

(test #5d-attack-roll-with-spite)
	(roll 5 #d6 22 with 0 spite)
	(roll 5 #d6 25 with 0 spite)
	(roll 5 #d6 17 with 2 spite)
	(roll 5 #d6 24 with 0 spite)

(test #6d-attack-roll-with-spite)
	(roll 6 #d6 23 with 1 spite)
	(roll 6 #d6 31 with 0 spite)
	(roll 6 #d6 22 with 2 spite)
	(roll 6 #d6 28 with 0 spite)

(test #7-die-pool-against-target)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 5)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 1)

(test #8-die-pool-against-target)
	(roll 8 #d6 with target 5 into 3)
	(roll 8 #d6 with target 5 into 5)
	(roll 8 #d6 with target 5 into 4)
	(roll 8 #d6 with target 5 into 2)
	(roll 8 #d6 with target 5 into 1)

(test #9-die-pool-against-target)
	(roll 9 #d6 with target 5 into 4)
	(roll 9 #d6 with target 5 into 6)
	(roll 9 #d6 with target 5 into 4)
	(roll 9 #d6 with target 5 into 3)
	(roll 9 #d6 with target 5 into 1)

(test #zero-percent)
	(percentage of 0 into 0)

(test #one-percent)
	(percentage of 1 into 1)
